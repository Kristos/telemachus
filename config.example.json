{
  "_comment": "Telemachus config examples. Copy ONE of the configs below into ~/.telemachus/config.json. Set required env vars (see .env.example).",
  "_minimal": {
    "_description": "Anthropic + Discord only — simplest setup",
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "providerConfigs": {
      "anthropic": {
        "apiKey": "set-via-ANTHROPIC_API_KEY-env-var"
      }
    },
    "discord": {
      "tokenEnv": "DISCORD_BOT_TOKEN",
      "allowedUsers": []
    }
  },
  "_full": {
    "_description": "All providers, both transports, example agent job, example MCP server",
    "provider": "anthropic",
    "fallbackProvider": "openai-compat",
    "model": "claude-sonnet-4-6",
    "windowSize": 40,
    "permissionMode": "yolo",
    "temperature": 0.7,
    "maxIterations": 50,
    "toolTimeoutMs": 30000,
    "autoCompactThreshold": 90,
    "providerConfigs": {
      "anthropic": {
        "apiKey": "set-via-ANTHROPIC_API_KEY-env-var"
      },
      "openai-compat": {
        "apiKey": "set-via-OPENAI_API_KEY-env-var",
        "baseURL": "https://api.openai.com/v1",
        "model": "gpt-4o"
      },
      "llamacpp": {
        "baseURL": "http://localhost:8080/v1",
        "model": "your-local-model.gguf"
      }
    },
    "discord": {
      "tokenEnv": "DISCORD_BOT_TOKEN",
      "allowedUsers": []
    },
    "telegram": {
      "tokenEnv": "TELEGRAM_BOT_TOKEN",
      "ownerChatId": "set-via-TELEGRAM_OWNER_CHAT_ID-env-var"
    },
    "mcpServers": {
      "_example_mcp": {
        "_comment": "Example MCP server config. Replace with your own.",
        "command": "node",
        "args": ["/path/to/your-mcp/index.js"],
        "env": {
          "API_KEY": "${YOUR_MCP_API_KEY}"
        }
      }
    },
    "agents": {
      "_example_job": {
        "_comment": "Example agent job. See docs/examples/agent-jobs.json for more.",
        "schedule": "0 9 * * *",
        "provider": "anthropic",
        "model": "claude-sonnet-4-6",
        "prompt": "Your agent's task description goes here.",
        "notify": {
          "type": "discord-webhook",
          "url": "REPLACE_ME"
        }
      }
    }
  }
}
