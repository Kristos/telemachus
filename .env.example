# Telemachus environment configuration.
# Copy to `.env` and fill in your values. NEVER commit .env to git.

# === Discord bot ===
# Bot token from Discord Developer Portal -> Bot -> Token
DISCORD_BOT_TOKEN=your-discord-bot-token-here
# Your Discord user ID (18-digit snowflake) — becomes the bot owner / sole allowed user
DISCORD_OWNER_ID=your-discord-user-id-here

# === Telegram bot ===
# Bot token from @BotFather (/newbot)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Your Telegram chat ID — start a chat with the bot and use getUpdates to find it
TELEGRAM_OWNER_CHAT_ID=your-telegram-chat-id-here

# === LLM providers ===
# Anthropic API key for Claude models
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OpenAI API key (or any OpenAI-compatible provider: Z.ai, OpenRouter, etc.)
OPENAI_API_KEY=your-openai-api-key-here

# === Local llama.cpp (optional) ===
# Override the llama.cpp baseURL — useful when pointing at a remote rig over Tailscale.
# Falls back to KC_LLAMACPP_BASE_URL (deprecated alias) if not set.
LLAMACPP_BASE_URL=http://localhost:8080/v1

# === Provider / model overrides (optional) ===
# KC_PROVIDER: anthropic | openai-compat | llamacpp
# KC_MODEL: any model string supported by the active provider
# Both override config.json values without editing the file.
# KC_PROVIDER=anthropic
# KC_MODEL=claude-sonnet-4-6

# ------------------------------------------------------------------
# Sandboxing note (DOCKER-05):
# The `sandbox-exec` tool wrapper is macOS-only. On Linux (and inside
# this Docker image) it falls back to a no-op sandbox automatically
# — see src/tools/sandbox/index.ts. Container isolation is provided
# by Docker itself; no extra configuration is required.
# ------------------------------------------------------------------
