{
  "name": "telemachus",
  "version": "4.0.0",
  "type": "module",
  "bin": {
    "tm": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "build:compile": "bun build --compile src/index.ts --outfile tm",
    "docs:dev": "cd docs && bun run dev",
    "docs:build": "cd docs && bun run build",
    "docs:preview": "cd docs && bun run preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/stream": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "discord.js": "^14.26.2",
    "gpt-tokenizer": "^3.4.0",
    "grammy": "^1.42.0",
    "ink": "^5.2.1",
    "openai": "^4",
    "react": "^18.3.1",
    "turndown": "^7.2.4",
    "zod": "^3.25",
    "zod-to-json-schema": "^3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/react": "^18",
    "@types/turndown": "^5",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5"
  },
  "description": "A self-hosted AI assistant for Discord, Telegram, and terminal. Bring your own LLM \u2014 Anthropic, OpenAI-compatible, or local llama.cpp.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kristos/telemachus.git"
  },
  "homepage": "https://github.com/Kristos/telemachus",
  "bugs": {
    "url": "https://github.com/Kristos/telemachus/issues"
  }
}
